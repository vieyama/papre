# Local development only. Docker Compose constructs its internal URL from
# POSTGRES_* and connects through the "postgres" service.
COMPOSE_PROJECT_NAME="papre"
DATABASE_URL="postgresql://papre_user:password@localhost:5432/papre"
POSTGRES_USER="papre_user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="papre"

AUTH_URL="http://localhost:3010"
AUTH_SECRET="replace-me"
APP_BIND_ADDRESS="0.0.0.0"
APP_PORT="3010"
DATA_ENCRYPTION_MASTER_KEY="replace-with-output-of-openssl-rand-base64-32"

MINIO_ENDPOINT="127.0.0.1"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="papre"

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_FROM_ADDRESS="no-reply@example.com"
SMTP_FROM_NAME="Papre"
SMTP_USERNAME="smtp-user"
SMTP_PASSWORD="smtp-password"
